---
interface Props {
    href: string;
    image: string;
    imageAlt: string;
    category: string;
    title: string;
}

const { href, image, imageAlt, category, title } = Astro.props;
---

<a href={href} class="work-card">
    <div class="work-image">
        <img src={image} alt={imageAlt}>
    </div>
    <div class="work-info">
        <div class="work-text">
            <p class="work-category">{category}</p>
            <h3 class="work-title">{title}</h3>
        </div>
        <span class="material-icons work-arrow">arrow_forward</span>
    </div>
</a>

<style>
    .work-card {
        background: var(--gray-white);
        border: 1px solid var(--gray-divider);
        padding: 40px;
        display: flex;
        flex-direction: column;
        gap: 40px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .work-card:hover {
        background: var(--primary-opacity);
        border: 1px solid var(--primary-orange);
    }

    .work-card:hover .work-arrow {
        color: var(--primary-orange);
    }

    .work-image {
        width: 100%;
        aspect-ratio: 1;
        border: 1px solid var(--gray-divider);
        overflow: hidden;
    }

    .work-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .work-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
    }

    .work-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .work-category {
        font-size: var(--fs-body);
        line-height: 28px;
        color: var(--gray-sub);
    }

    .work-title {
        font-family: var(--font-en);
        font-size: var(--fs-heading-sm);
        font-weight: 700;
        color: var(--gray-main);
        line-height: 1;
    }

    .work-arrow {
        font-size: 40px;
        color: var(--gray-sub);
        transition: color 0.3s ease;
    }
</style>
