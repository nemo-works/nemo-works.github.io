---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div class="tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
)}

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    background: var(--gray-white);
    border: 1px solid var(--gray-divider);
    padding: 4px 16px;
    border-radius: 9999px;
    font-size: var(--fs-tag);
    line-height: 19px;
    color: var(--gray-main);
  }
</style>
