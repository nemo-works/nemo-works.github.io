---
interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = 'YouTube動画' } = Astro.props;
---

<section class="youtube-embed">
  <div class="video-wrapper">
    <iframe
      src={`https://www.youtube.com/embed/${videoId}`}
      title={title}
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
</section>

<style>
  .youtube-embed {
    border-top: 1px solid var(--gray-divider);
    border-bottom: 1px solid var(--gray-divider);
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
