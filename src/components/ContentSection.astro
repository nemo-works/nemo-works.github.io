---
/**
 * ContentSection
 *
 * maintext 内でテキストを ==...== で囲むと黄色背景でハイライト表示されます。
 *
 * 例:
 *   maintext='通常テキスト。==ここがハイライト==されます。'
 *
 * 複数箇所指定も可能:
 *   maintext='==最初==のハイライトと==2つ目==のハイライト。'
 */
interface Props {
    title: string;
    maintext: string;
}

const { title, maintext } = Astro.props;

function parseHighlight(text: string) {
    const parts: { text: string; highlight: boolean }[] = [];
    const regex = /==(.+?)==/g;
    let lastIndex = 0;
    let match;
    while ((match = regex.exec(text)) !== null) {
        if (match.index > lastIndex) {
            parts.push({ text: text.slice(lastIndex, match.index), highlight: false });
        }
        parts.push({ text: match[1], highlight: true });
        lastIndex = regex.lastIndex;
    }
    if (lastIndex < text.length) {
        parts.push({ text: text.slice(lastIndex), highlight: false });
    }
    return parts;
}
---

<section class="content-section">
    <h2 class="content-section-title">
        {title.split('\n').map((line, i, arr) => (
            <Fragment>{line}{i < arr.length - 1 && <br />}</Fragment>
        ))}
    </h2>
    <p class="content-section-main">
        {maintext.split('\n').map((line, i, arr) => (
            <Fragment>
                {parseHighlight(line).map(part =>
                    part.highlight
                        ? <mark class="highlight">{part.text}</mark>
                        : part.text
                )}
                {i < arr.length - 1 && <br />}
            </Fragment>
        ))}
    </p>
</section>

<style>
    .content-section {
        background-color: var(--gray-white);
        border-top: 1px solid var(--gray-divider);
        border-bottom: 1px solid var(--gray-divider);
        padding: 40px 70px;
    }

    .content-section-title {
        font-size: var(--fs-heading-sm);
        padding-bottom: 20px;
    }

    .content-section-main {
        font-size: var(--fs-read);
        line-height: 2;
        color: var(--gray-main);
    }

    .highlight {
        background-color: transparent;
        background-image: linear-gradient(var(--highlight), var(--highlight));
        background-repeat: no-repeat;
        background-size: 0% 100%;
        background-position: left center;
        color: inherit;
        padding: 0 2px;
        transition: background-size 1.25s ease;
    }

    .content-section.is-visible .highlight {
        background-size: 100% 100%;
    }
</style>

<script>
    const observe = () => {
        const sections = document.querySelectorAll('.content-section');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const highlights = entry.target.querySelectorAll<HTMLElement>('.highlight');
                    highlights.forEach((el, i) => {
                        el.style.transitionDelay = `${1 + i * 0.5}s`;
                    });
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.2 });

        sections.forEach(s => observer.observe(s));
    };

    observe();
    document.addEventListener('astro:page-load', observe);
</script>
