---
interface Props {
  subtitle: string;
  title: string;
  animated?: boolean;
}

const { subtitle, title, animated = true } = Astro.props;
const chars = animated ? title.split('') : null;
---

<div class="section-header" data-animated={animated || undefined}>
  <p class="section-subtitle">{subtitle}</p>
  <h2 class="section-title">
    {animated && chars ? (
      chars.map((char, i) => (
        <span
          class="char"
          style={`transition-delay: calc(var(--anim-char-slow-start) + ${i} * var(--anim-char-slow-step))`}
        >{char === ' ' ? '\u00A0' : char}</span>
      ))
    ) : title}
  </h2>
</div>

<style>
  .section-header {
    background: var(--gray-white);
    border-top: 1px solid var(--gray-divider);
    border-bottom: 1px solid var(--gray-divider);
    padding: 40px 70px;
  }

  .section-subtitle {
    font-size: var(--fs-sub);
    font-weight: 500;
    color: var(--gray-sub);
    margin-bottom: 12px;
  }

  .section-title {
    font-family: var(--font-en);
    font-size: var(--fs-heading-lg);
  }

  .char {
    display: inline-block;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity var(--anim-char-slow-duration) ease, transform var(--anim-char-slow-duration) ease;
  }

  .section-title.is-visible .char {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .section-header { padding: 32px 24px; }
    .section-title { font-size: 32px; }
  }
</style>

<script>
  const observe = () => {
    const headers = document.querySelectorAll('.section-header[data-animated]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.querySelector('.section-title')?.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    headers.forEach(h => observer.observe(h));
  };

  observe();
  document.addEventListener('astro:page-load', observe);
</script>
