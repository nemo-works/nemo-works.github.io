---
---

<div class="password-overlay" id="passwordOverlay">
    <div class="password-box">
        <h2>🔒 Portfolio</h2>
        <p>このサイトは根本壮馬のポートフォリオです。<br>このポートフォリオは掲載内容を考慮し、パスワードで保護されています<br>根本より共有されたパスワードを入力してください</p>
        <form id="passwordForm">
            <input
                type="password"
                class="password-input"
                id="passwordInput"
                placeholder="パスワードを入力"
                autocomplete="off"
                autofocus
            >
            <button type="submit" class="password-submit">ログイン</button>
            <p class="password-error" id="passwordError">パスワードが違います</p>
        </form>
    </div>
</div>

<style>
    .password-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, #e17f2c 0%, #d16d1f 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        opacity: 1;
        transition: opacity 0.5s ease;
    }

    .password-overlay.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .password-box {
        background: white;
        padding: 48px;
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        max-width: 400px;
        width: 90%;
        text-align: center;
    }

    .password-box h2 {
        font-size: 28px;
        margin-bottom: 12px;
        color: var(--gray-main);
    }

    .password-box p {
        font-size: 14px;
        color: var(--gray-sub);
        margin-bottom: 32px;
    }

    .password-input {
        width: 100%;
        padding: 16px;
        border: 2px solid #ddd;
        border-radius: 12px;
        font-size: 16px;
        font-family: inherit;
        margin-bottom: 16px;
        transition: border-color 0.3s ease;
    }

    .password-input:focus {
        outline: none;
        border-color: var(--primary-orange);
    }

    .password-submit {
        width: 100%;
        padding: 16px;
        background: var(--primary-orange);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .password-submit:hover {
        background: #d16d1f;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(225, 127, 44, 0.4);
    }

    .password-error {
        color: #e74c3c;
        font-size: 14px;
        margin-top: 12px;
        display: none;
    }

    .password-error.show {
        display: block;
    }
</style>

<script>
    const CORRECT_PASSWORD_HASH = '7367c98b14b9b37fcf0dd9bd6eb45e8671bed22fe70f085013ecae052eea27a4';

    async function hashPassword(password: string): Promise<string> {
        const encoder = new TextEncoder();
        const data = encoder.encode(password);
        const hashBuffer = await crypto.subtle.digest('SHA-256', data);
        const hashArray = Array.from(new Uint8Array(hashBuffer));
        return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
    }

    function unlockSite() {
        const overlay = document.getElementById('passwordOverlay');
        if (!overlay) return;
        overlay.classList.add('hidden');
        document.body.classList.remove('locked');
        setTimeout(() => {
            overlay.style.display = 'none';
        }, 500);
    }

    function showError() {
        const errorElement = document.getElementById('passwordError');
        if (!errorElement) return;
        errorElement.classList.add('show');
        setTimeout(() => {
            errorElement.classList.remove('show');
        }, 3000);
    }

    async function init() {
        const savedHash = sessionStorage.getItem('portfolioAuth');
        if (savedHash === CORRECT_PASSWORD_HASH) {
            unlockSite();
            return;
        }

        document.body.classList.add('locked');

        const form = document.getElementById('passwordForm') as HTMLFormElement;
        const input = document.getElementById('passwordInput') as HTMLInputElement;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const hash = await hashPassword(input.value);
            if (hash === CORRECT_PASSWORD_HASH) {
                sessionStorage.setItem('portfolioAuth', hash);
                unlockSite();
            } else {
                showError();
                input.value = '';
                input.focus();
            }
        });
    }

    document.addEventListener('DOMContentLoaded', init);
</script>
