---
import TagList from './TagList.astro';
import ThoughtBubble from './ThoughtBubble.astro';

interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  subtitle?: string;
  title: string;
  description: string;
  tags?: string[];
  period: string;
  tasks: string[];
  members: string[];
  thoughtBubble?: string;
  variant?: 'overview' | 'detail';
  images?: ImageItem[];
  imageLayout?: 'single' | 'multi';
}

const {
  subtitle,
  title,
  description,
  tags,
  period,
  tasks,
  members,
  thoughtBubble,
  variant = 'overview',
  images = [],
  imageLayout = 'single',
} = Astro.props;

const titleLines = title.split('\n');
---

<section class:list={['content-header', `variant-${variant}`]}>
  <div class="header-block">
    {subtitle && <p class="subtitle">{subtitle}</p>}
    <h1 class="title">
      {titleLines.map((line, i, arr) => (
        <Fragment>{line}{i < arr.length - 1 && <br />}</Fragment>
      ))}
    </h1>
    <p class="description">
      {description.split('\n').map((line, i, arr) => (
        <Fragment>{line}{i < arr.length - 1 && <br />}</Fragment>
      ))}
    </p>
    {tags && tags.length > 0 && <TagList tags={tags} />}
  </div>

  <div class="info-block">
    <div class="info-item">
      <div class="info-row">
        <span class="info-label">対応期間</span>
        <div class="info-divider"></div>
      </div>
      <div class="info-content">{period}</div>
    </div>

    <div class="info-item">
      <div class="info-row">
        <span class="info-label">やったこと</span>
        <div class="info-divider"></div>
      </div>
      <div class="info-content">
        {tasks.map((task, i) => (
          <Fragment>{task}{i < tasks.length - 1 && <br />}</Fragment>
        ))}
      </div>
    </div>

    <div class="info-item">
      <div class="info-row">
        <span class="info-label">メンバー構成</span>
        <div class="info-divider"></div>
      </div>
      <div class="info-content-wrap">
        <div class="info-content">
          {members.map((member, i) => (
            <Fragment>{member}{i < members.length - 1 && <br />}</Fragment>
          ))}
        </div>
        {thoughtBubble && <ThoughtBubble text={thoughtBubble} />}
      </div>
    </div>
  </div>

  {images.length > 0 && (
    <div class:list={['image-block', `layout-${imageLayout}`]}>
      {images.map(img => (
        <div class="image-item">
          <img src={img.src} alt={img.alt} />
        </div>
      ))}
    </div>
  )}
</section>

<style>
  .content-header {
    display: flex;
    flex-direction: column;
    gap: 40px;
    background: var(--gray-white);
  }

  .header-block {
    background: var(--gray-white);
    border-top: 1px solid var(--gray-divider);
    border-bottom: 1px solid var(--gray-divider);
    padding: 40px 70px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .subtitle {
    font-size: var(--fs-sub);
    font-weight: 500;
    color: var(--gray-sub);
    line-height: 1;
  }

  .title {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 1.2s ease, transform 1.5s ease;
    transition-delay: 0.1s;
  }

  .title.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* overview variant: 英語タイトル向け */
  .variant-overview .title {
    font-family: var(--font-en);
    font-size: var(--fs-heading-lg);
    font-weight: 700;
    line-height: 1.4;
    color: var(--gray-main);
  }

  /* detail variant: 日本語タイトル向け */
  .variant-detail .title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.5;
    color: var(--gray-main);
  }

  .description {
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--gray-main);
  }

  .info-block {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 0 40px;
  }

  .info-item:first-child {
    padding-left: 70px;
  }

  .info-item:last-child {
    padding-right: 70px;
  }

  .info-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .info-label {
    font-size: var(--fs-sub);
    font-weight: 500;
    color: var(--gray-sub);
    white-space: nowrap;
  }

  .info-divider {
    flex: 1;
    height: 1px;
    background: var(--gray-divider);
  }

  .info-content-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .info-content {
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--gray-main);
  }

  /* --- Image Block --- */

  /* single: 1枚をコンポーネント全幅表示 */
  .image-block.layout-single .image-item img {
    width: 100%;
    height: auto;
    display: block;
    border-top: 1px solid var(--gray-divider) ;
  }

  /* multi: 2カラムグリッド表示 */
  .image-block.layout-multi {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
  }

  /* 奇数枚のとき最後の1枚を全幅に */
  .image-block.layout-multi .image-item:last-child:nth-child(odd) {
    grid-column: 1 / -1;
  }

  .image-block.layout-multi .image-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* --- Responsive --- */

  @media (max-width: 1024px) {
    .info-block {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .info-item {
      padding: 0 70px;
    }

    .info-item:first-child,
    .info-item:last-child {
      padding-left: 70px;
      padding-right: 70px;
    }
  }

  @media (max-width: 768px) {
    .header-block {
      padding: 30px 20px;
    }

    .variant-overview .title {
      font-size: var(--fs-heading-md);
    }

    .variant-detail .title {
      font-size: var(--fs-heading-sm);
    }

    .description {
      font-size: var(--fs-body);
      line-height: 1.8;
      color: var(--gray-main);
    }

    .info-block {
      gap: 30px;
    }

    .info-item {
      gap: 10px;
    }

    .info-content {
      font-size: var(--fs-body);
      line-height: 1.8;
      color: var(--gray-main);
    }

    .info-content-wrap {
    gap: 4px;
    }

    .info-item,
    .info-item:first-child,
    .info-item:last-child {
      padding-left: 30px;
      padding-right: 30px;
    }

    .info-block { order: 2; margin-bottom: 40px; }
    .image-block { order: 1; margin-top: -40px; }

    .image-block.layout-multi {
      grid-template-columns: 1fr;
    }

    .image-block.layout-multi .image-item:last-child:nth-child(odd) {
      grid-column: auto;
    }
  }
</style>

<script>
  const observe = () => {
    const headers = document.querySelectorAll('.content-header');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.querySelector('.title')?.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    headers.forEach(h => observer.observe(h));
  };

  observe();
  document.addEventListener('astro:page-load', observe);
</script>
