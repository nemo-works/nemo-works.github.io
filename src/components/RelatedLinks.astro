---
import IconLink from './IconLink.astro';

interface Link {
  href: string;
  label: string;
}

interface Props {
  links: Link[];
}

const { links } = Astro.props;
---

<section class="related-links">
  <h2 class="related-links-title">関連リンク</h2>
  <div class="links-list">
    {links.map((link) => (
      <IconLink href={link.href} label={link.label} external />
    ))}
  </div>
</section>

<style>
  .related-links {
    background: var(--gray-white);
    padding: 40px 70px;
    border-top: 1px solid var(--gray-divider);
  }

  .related-links-title {
    font-size: var(--fs-heading-sm);
    margin-bottom: 20px;
  }

  .links-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  @media (max-width: 768px) {
    .related-links {
      padding: 24px;
    }

    .related-links-title {
      font-size: var(--fs-sub);
    }
  }
</style>
