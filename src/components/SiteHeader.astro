---
interface Props {
  variant: 'menu' | 'back';
  backHref?: string;
  logoDark?: boolean; // true: 黒ロゴ(明るい背景), false: 白ロゴ(暗い背景) デフォルト: true
}

const { variant, backHref = '/', logoDark = true } = Astro.props;
---

<header class:list={['site-header', `site-header--${variant}`]}>
  {variant === 'back' ? (
    <a href={backHref} class="header-button">
      <span class="material-icons">arrow_back</span>
      <span>BACK</span>
    </a>
  ) : (
    <button class="header-button">
      <span class="material-icons">menu</span>
      <span>MENU</span>
    </button>
  )}

  <div class:list={['header-logo', logoDark ? 'logo--dark' : 'logo--light']}>
