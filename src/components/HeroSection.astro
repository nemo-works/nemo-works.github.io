---
const titleLines = ['シンプルで、', '明快な' , 'デザインを。'];
let charIdx = 0;
type Token = { type: 'char'; char: string; index: number } | { type: 'br' };
const titleTokens: Token[] = [];
titleLines.forEach((line, lineIdx) => {
    line.split('').forEach(char => titleTokens.push({ type: 'char', char, index: charIdx++ }));
    if (lineIdx < titleLines.length - 1) titleTokens.push({ type: 'br' });
});
---

<section class="hero">
    <div class="hero-content">
        <div class="hero-text">
            <h1 class="hero-title">
                {titleTokens.map(token =>
                    token.type === 'br'
                        ? <br />
                        : <span class="char" style={`transition-delay: calc(var(--anim-char-slow-start) + ${token.index} * var(--anim-char-slow-step))`}>{token.char}</span>
                )}
            </h1>
            <p class="hero-name">SOMA NEMOTO</p>
            <p class="hero-description">シンプルで、明快な、デザインで<br>日々に少しの喜びを与えられるサービスを届けられる<br>デザイナーを志しています。</p>
        </div>
        <div class="hero-image">
            <img src="/img/index/top-icon.png" alt="Soma Nemoto">
        </div>
    </div>
</section>

<style>
    .hero {
        background: #FCFAF2;
        /* min-height: 920px; */
        padding: 80px 200px;
        display: flex;
        justify-content: center;
        align-items: flex-end;
        position: relative;
        overflow: hidden;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: var(--max-width);
        display: flex;
        gap: 20px;
    }

    .hero-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        gap: 24px;
        color: var(--gray-main);
    }

    .hero-title {
        font-size: 3.25vw;
        font-weight: 700;
        line-height: 160%;
        letter-spacing: 8%;
    }

    .char {
        display: inline-block;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity var(--anim-char-slow-duration) ease, transform var(--anim-char-slow-duration) ease;
    }

    .hero-title.is-visible .char {
        opacity: 1;
        transform: translateY(0);
    }

    .hero-name {
        font-family: var(--font-en);
        font-size: 2.75vw;
        font-weight: 700;
        line-height: 48px;
    }

    .hero-description {
        font-size: var(--fs-sub);
        line-height: 210%;
    }

    .hero-image {
        /* flex: 1;*/
        display: flex;
        justify-content: end;
        align-items: flex-end;
    }

    .hero-image img {
        width: 280px;
        height: 280px;
        border-radius: 50%;
        object-fit: cover;
        cursor: pointer;
    }

    .hero-image img.wiggle {
        animation: wiggle 0.5s ease;
    }

    @keyframes wiggle {
        0%   { transform: rotate(0deg); }
        30%  { transform: rotate(-10deg); }
        100% { transform: rotate(0deg); }
    }

    @media (max-width: 1440px) {
        .hero {
            padding-left: 80px;
            padding-right: 80px;
        }
    }

    @media (max-width: 1024px) {
        .hero-content {
            flex-direction: column;
            align-items: center;
        }
        .hero-text {
            align-items: center;
            text-align: center;
        }
        .hero-image { justify-content: center; }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 100px 24px 40px;
            height: 100svh; /* JSで上書きされる */
            align-items: stretch;
        }
        .hero-content {
            flex-direction: column;
            align-items: start;
        }
        .hero-text {
            padding-left: 4vw;
            align-items: flex-start;
            justify-content: center;
            text-align: left;
        }
        .hero-image {
            padding-right: 2vw;
            width: 100%;
            justify-content: right;
            align-items: end;
            flex-direction: row-reverse;
        }
        .hero-title { font-size: 36px; }
        .hero-name { font-size: 32px; }
        .hero-description { font-size: 16px; }
        .hero-image img { width: 40svw; height: auto; }
    }
</style>

<script>
    // SPでheroの高さをロード時に固定（アドレスバーの出し隠しによる変動を防ぐ）
    const fixHeroHeight = () => {
        const hero = document.querySelector<HTMLElement>('.hero');
        if (hero && window.innerWidth <= 768) {
            hero.style.height = `${window.innerHeight}px`;
        }
    };
    fixHeroHeight();
    document.addEventListener('astro:page-load', fixHeroHeight);

    const observe = () => {
        const title = document.querySelector('.hero-title');
        if (!title) return;
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        observer.observe(title);
    };

    observe();
    document.addEventListener('astro:page-load', observe);

    const heroImg = document.querySelector<HTMLImageElement>('.hero-image img');
    heroImg?.addEventListener('click', () => {
        heroImg.classList.remove('wiggle');
        void heroImg.offsetWidth;
        heroImg.classList.add('wiggle');
    });
    heroImg?.addEventListener('animationend', () => {
        heroImg.classList.remove('wiggle');
    });
</script>
