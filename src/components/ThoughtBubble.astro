---
interface Props {
  text: string;
  iconSrc?: string;
  iconAlt?: string;
}

const {
  text,
  iconSrc = '/img/index/top-icon.png',
  iconAlt = 'nemoto icon',
} = Astro.props;
---

<div class="thought-bubble">
  <img class="bubble-icon" src={iconSrc} alt={iconAlt} />
  <span class="bubble-text">{text}</span>
</div>

<style>
  .thought-bubble {
    display: flex;
    align-items: center;
    width: fit-content;
    max-width: 100%;
    gap: 10px;
    padding: 4px 8px 4px 4px;
    /* background: #F0FAFF;
    border: 1px solid #BADEF0; */
    border-radius: 24px;
  }

  .bubble-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .bubble-text {
    font-size: var(--fs-tag);
    color: var(--gray-main);
    line-height: 1;
    white-space: normal;
  }
</style>
