---
import DetailLayout from '../../../layouts/DetailLayout.astro';
import ContentHeader from '../../../components/ContentHeader.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ContentSection from '../../../components/ContentSection.astro';
import FeatureCarousel from '../../../components/FeatureCarousel.astro';
import NavFooter from '../../../components/NavFooter.astro';
import { alkooWorks } from '../../../data/alkoo';

const work = alkooWorks.find(w => w.id === 'steps-sharing')!;
---

<DetailLayout
  title="歩数共有機能"
  backHref="/alkoo"
  breadcrumb={[
    { label: "TOP", href: "/" },
    { label: "ALKOO", href: "/alkoo" },
    { label: "歩数共有機能" },
  ]}
>
  <div class="content-intro">
    <ContentHeader
      variant="detail"
      title="歩数を画像・イラストに載せて友人や家族に共有。
      周囲の人に今日の思い出と歩数を共有して日々のモチベーションを維持。"
      description="毎日の歩数を写真やイラストを添えてSNS共有。今日と今日の歩みを分かち合い、ユーザー像の理解がより確実なものに。"
      tags={work.tags}
      period="2025年4月〜2025年6月"
      tasks={["仕様検討", "UI検討","機能提案"]}
      members={["PM…1名", "エンジニア…2名", "デザイナー…1名"]}
      thoughtBubble='メインデザイナーを担当しました'
      images={[{ src: "/img/steps-sharing/kv.jpg", alt: "歩数共有機能" }]}
      imageLayout="single"
    />

    <!-- 概要 -->
    <ContentSection
        title='機能概要'
        maintext=
        '歩数を自分が撮影した画像やイラストに載せてSNSに共有ができるシンプルな機能です。
        ですが、この機能によってALKOOに求められている機能の需要、ユーザー像が今まで以上に明確になりました。
        '
    />
  </div>

  <div class="sections-list">
    <SectionHeader subtitle="開発経緯とUIUX検討" title="STORY" />
    <ContentSection
        title='開発の経緯'
        maintext=
        'ALKOOの記録機能は、その日撮った写真と一緒に歩数が見れるようになっています。これにより、記録を思い出として振り返れるようなアプリになっているため、写真と歩数を合わせてSNSなどで共有できる機能があると意外と使ってくれるのではないかというチーム内での改善MTGでの会話が着想となっています。
        '
    />
    <ContentSection
        title='どんな情報を載せるか？'
        maintext=
        '最初に写真と歩数を一緒にした画像をまず作れるようにしましたが、==「イラスト」をデフォルトで設定し、写真がない日でもユーザーの用途に合わせて気軽に映える近況報告ができる==状態を目指しました。
        また、これ以外にも「歩数円」バージョンや写真と移動ログを一緒にした画像も作成しバリエーション豊富な画像共有ができるようにしました。
        '
    />
    
    <ContentSection
        title='グロースに向けた考慮'
        maintext=
        '共有をどこからできるようにするかという点で、私から提案したのが歩数円の下にボタンを追加するという案です。
        グロース面で考えると共有してくれるユーザーは新しいユーザーへの繋がりになりますし、日々の頑張りを誰かに伝えるという使い方はユーザーの運動習慣の継続にも役立つと考え、==ホーム画面の歩数円のすぐ下に配置し、アプリの利用サイクルとして自然に共有がされるように意識しました。 ==
        また、画像内にアイコンとロゴを入れることで、どのアプリから共有されたか説明しなくても画像を見ればわかる状態も考慮しました。
        '
    />
      <!-- Feature Image -->
    <FeatureCarousel images={[
      { src: "/img/steps-sharing/img_step_share_cap001.jpg", alt: "作成できる画像の種類", caption: "作成できる画像の種類" },
      { src: "/img/steps-sharing/img_step_share_cap002.jpg", alt: "歩数円の下に置きユーザーに共有という新しい使い方を提示した", caption: "歩数円の下に「共有ボタン」を置き、ユーザーとしてもサービスとしても新しい使い方を提示することにした" },
    ]} />
  </div>

  <div class="sections-list">
    <SectionHeader subtitle="反響と利用実績" title="OUTCOME"/>
    <ContentSection
        title='「家族」への共有が1番'
        maintext=
        'リリースの結果、==LINEでの共有が一番多く==、次いでXでの共有となっていて、顔見知り以上に、家族や身近な友人への共有が多いという実態が見えました。
        確かに、法人の引き合いでも家族への歩数の共有を通して見守りが行える機能が欲しいなどのお声があったため、一定数の需要は最初から窺えていましたが、実際の利用実績も同様のものになっていたため、需要の証明ができる結果となりました。
        '
    />
    <ContentSection
        title='「#ALKOOで歩こう」でユーザーの頑張りを知ることができた'
        maintext=
        'Xで共有した際には「#ALKOOで歩こう」というタグがつくようになっていて、ユーザーが画像を投稿すると我々やユーザー同士でお互いの今日の歩数が確認できるようにしました。
        投稿してくださっているユーザーの中には持病の対策として歩きはじめた人、少しでも痩せるために毎日頑張ると決めた人、さまざまな事情で歩きはじめた人に気づくことができました。
        この機能を入れたことではじめて多くの人の頑張りを身近に感じるようになり、==ユーザー像の理解、アプリを利用するきっかけを今まで以上に真剣に理解できるようになった==施策・機能でした。
        '
    />
  </div>

  <!-- Navigation Footer -->
  <NavFooter works={alkooWorks} currentId="steps-sharing" />
</DetailLayout>
