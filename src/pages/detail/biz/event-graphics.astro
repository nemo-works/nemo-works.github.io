---
import DetailLayout from '../../../layouts/DetailLayout.astro';
import ContentHeader from '../../../components/ContentHeader.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ContentSection from '../../../components/ContentSection.astro';
import FeatureCarousel from '../../../components/FeatureCarousel.astro';
import RelatedLinks from '../../../components/RelatedLinks.astro';
import NavFooter from '../../../components/NavFooter.astro';
import { alkooBizWorks } from '../../../data/alkoo_biz';

const work = alkooBizWorks.find(w => w.id === 'event-graphics')!;
---

<DetailLayout
  title="イベントグラフィックデザイン"
  backHref="/alkoo_biz"
  breadcrumb={[
    { label: "TOP", href: "/" },
    { label: "ALKOO法人", href: "/alkoo_biz" },
    { label: "イベントグラフィックデザイン" },
  ]}
>

  <ContentHeader
    variant="detail"
    title="お客様が検討したイベントの楽しさが伝わるように。\n『イベントの顔』となるグラフィックデザインで、お客様を支援しました。"
    description="2021年ごろから法人顧客の対応を先輩から引き継ぎ、以降、顧客の希望に応じてグラフィックデザインの作成も行なっています。制作したものはチラシ・ロゴ・LPなど多岐にわたります。"
    tags={work.tags}
    period="2021年〜"
    tasks={["顧客折衝","告知物デザイン作成","販促物作成"]}
    members={["PM…1名","セールス…1~2名","エンジニア…1名", "デザイナー…1名"]}
    thoughtBubble='各案件でリードデザイナーを担当しました'
    images={[{ src: "/img/kobaton/kv.png", alt: "コバトンALKOOマイレージキービジュアル" }]}
    imageLayout="single"
  />

  <div class="sections-list">
    <SectionHeader subtitle="岐阜県各務原市様 | かかみがはらフレイル予防ウォーキング" title="CASE-01" />
    
    <!-- イベント概要 -->
    <ContentSection
        title='「かかみがはらフレイル予防ウォーキング」とは'
        maintext='各務原市に在住の40歳以上の方を対象に、加齢に伴い運動量などが低下し、慢性的な虚弱体質が続く「フレイル」状態を予防するための運動習慣獲得に向けた施策です。64歳以下の場合は40万歩、65歳以上の場合は35万歩を2ヶ月で稼ぐという少し難易度の高いイベントです。
        ==こちらのイベントでは、参加者が見るチラシのデザインと市役所で使用されるデジタルサイネージのデザインを対応いたしました。==
        '
    />

    <!-- Feature Image -->
    <FeatureCarousel images={[
      { src: "/img/event-graphics/event-graphics-001.jpg", alt: "UI・仕様上の工夫", caption:"フライヤーで市内全体に向けた告知を実施。フレイルに負けない元気なシニア像のイメージを提示。" },
    ]} />
    
    <!-- 結果 -->
    <ContentSection
        title='3年連続で参加者急増中。'
        maintext='本イベントは3年連続で実施していて、初年度は1,500人から、現在では3,000人を対象に参加人数が拡大しています。
        ==精力的に運動や趣味を楽しむ「活力のあるシニア」像が想像できるイラストを主題にし、参加するだけでも自分がフレイルとは程遠い元気な人だと前向きに思えるようなグラフィックを目指しました。==また、チラシは応募フォームとして使用することを前提としているため、字が書きやすい厚手の上質紙への印刷で発注を行っています。そのようなこだわりも伝わってか、作成したデザインも変更なく2年連続でご利用いただいております。
        '
    />
  </div>

  <div class="sections-list">
  <SectionHeader subtitle="沖縄セルラー様 | ちゅらウォーク" title="CASE-02"/>

    <!-- イベント講座 -->
    <ContentSection
        title='「ちゅらウォーク」とは'
        maintext='沖縄セルラー様が提供するヘルスケアアプリ「JOTOホームドクター」を用いて沖縄県とタッグを組んで開催するスマホで簡単に参加できるウォーキングイベントです。
        「みんなイキイキWELLNESS ISLAND」というテーマに沿って、==県全体がウォーキングを通して活力に溢れた夏になるというイメージで、沖縄を代表する動物や植物のイラストがわいわいと賑わって集まっているロゴデザインを目指しました。==
        '
    />
    <FeatureCarousel images={[
      { src: "/img/kobaton/img_kobaton_cap002.jpg", alt: "UI・仕様上の工夫", caption: "のぼりやマグネットステッカーを作成し、サービスの周知に活用しました" },
    ]} />
    <ContentSection
        title='チラシや、のぼり。集客ツール作成にも尽力'
        maintext='県の方のご提案で、受付窓口などに本イベントの参加を促進するミニのぼりやイベント実施中に使用するのぼりの作成も行いました。
        また、主要なユーザー層が高齢の方が中心であることも理解していたため、コールセンターの電話番号が確認できるマグネットステッカーも作成。
        集客ツールの作成にも尽力しました。
        '
    />
  </div>

  <div class="sections-list">
  <SectionHeader subtitle="三井不動産様 | ゆらり遊舟ぶらり日本橋" title="CASE-03"/>

    <!-- イベント講座 -->
    <ContentSection
        title='イベント参加講座でユーザーのリテラシーを理解'
        maintext='アンケートやユーザー情報を見たところ、利用者の半数が60代以上の高齢者層でした。
        採択当初から決まっていたイベント参加講座を県内53ヶ所で実施。そのうちのいくつかのイベントに自分も参加し、本イベントの参加登録までをサポートしました。利用者のリテラシーを深く理解する機会になりました。
        '
    />
    <FeatureCarousel images={[
      { src: "/img/kobaton/img_kobaton_cap002.jpg", alt: "UI・仕様上の工夫", caption: "のぼりやマグネットステッカーを作成し、サービスの周知に活用しました" },
    ]} />
    <!-- イベント講座 -->
    <ContentSection
        title='『鈴木次郎さんのイラスト × コレド室町の藍染め』が織りなす和モダンな世界観を目指して'
        maintext='アンケートやユーザー情報を見たところ、利用者の半数が60代以上の高齢者層でした。
        採択当初から決まっていたイベント参加講座を県内53ヶ所で実施。そのうちのいくつかのイベントに自分も参加し、本イベントの参加登録までをサポートしました。利用者のリテラシーを深く理解する機会になりました。
        '
    />
  </div>

  <!-- 関連リンク -->
  <RelatedLinks links={[
    { href: "https://www.city.kakamigahara.lg.jp/kenkofukushi/koureisha/1002527/1021399/1015508.html", label: "岐阜県各務原市様 | 『かかみがはらフレイル予防ウォーキング』概要ページ" },
    { href: "https://www.pref.okinawa.lg.jp/iryokenko/kenko/1006219/1031294.html", label: "沖縄セルラー様 | 『ちゅらウォーク』概要ページ" },
    { href: "https://static.cld.navitime.jp/walkingapp-storage/common/stamprally/nihonbashi_2022/index.html", label: "三井不動産様 | 『ゆらり遊舟ぶらり日本橋』LP" },
  ]} />

  <!-- Navigation Footer -->
  <NavFooter works={alkooBizWorks} currentId="event-graphics" />

</DetailLayout>
