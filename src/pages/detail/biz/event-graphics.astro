---
import DetailLayout from '../../../layouts/DetailLayout.astro';
import ContentHeader from '../../../components/ContentHeader.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ContentSection from '../../../components/ContentSection.astro';
import FeatureCarousel from '../../../components/FeatureCarousel.astro';
import RelatedLinks from '../../../components/RelatedLinks.astro';
import NavFooter from '../../../components/NavFooter.astro';
import { alkooBizWorks } from '../../../data/alkoo_biz';

const work = alkooBizWorks.find(w => w.id === 'event-graphics')!;
---

<DetailLayout
  title="イベントグラフィックデザイン"
  backHref="/alkoo_biz"
  breadcrumb={[
    { label: "TOP", href: "/" },
    { label: "ALKOO法人", href: "/alkoo_biz" },
    { label: "イベントグラフィックデザイン" },
  ]}
>

  <div class="content-intro">
    <ContentHeader
      variant="detail"
      title="お客様が検討したイベントの楽しさが伝わるように。\n『イベントの顔』となるグラフィックデザインで、お客様を支援しました。"
      description="2021年ごろから法人顧客の対応を先輩から引き継ぎ、以降、顧客の希望に応じてグラフィックデザインの作成も行なっています。制作したものはチラシ・ロゴ・LPなど多岐にわたります。"
      tags={work.tags}
      period="2021年〜"
      tasks={["顧客折衝","告知物デザイン作成","販促物作成"]}
      members={["PM…1名","セールス…1~2名","エンジニア…1名", "デザイナー…1名"]}
      thoughtBubble='各案件でリードデザイナーを担当しました'
      imageLayout="single"
    />
  </div>

  <div class="sections-list">
    <SectionHeader subtitle="岐阜県各務原市様 | かかみがはらフレイル予防ウォーキング(2023年〜)" title="CASE-01" />
    
    <!-- イベント概要 -->
    <ContentSection
        title='「かかみがはらフレイル予防ウォーキング」とは'
        maintext='各務原市に在住の40歳以上の方を対象に、加齢に伴い運動量などが低下し、慢性的な虚弱体質が続く「フレイル」状態を予防するための運動習慣獲得に向けた施策です。64歳以下の場合は40万歩、65歳以上の場合は35万歩を2ヶ月で稼ぐという少し難易度の高いイベントです。
        ==こちらのイベントでは、参加者が見るチラシのデザインと市役所で使用されるデジタルサイネージのデザインを対応いたしました。==
        '
    />

    <!-- Feature Image -->
    <FeatureCarousel images={[
      { src: "/img/event-graphics/event-graphics-001.jpg", alt: "岐阜県各務原市様 | かかみがはらフレイル予防ウォーキングチラシ", caption:"フライヤーで市内全体に向けた告知を実施。フレイルに負けない元気なシニア像のイメージを提示。" },
    ]} />
    
    <!-- 結果 -->
    <ContentSection
        title='3年連続で参加者急増中。'
        maintext='本イベントは3年連続で実施していて、初年度は1,500人から、現在では3,000人を対象に参加人数が拡大しています。
        ==精力的に運動や趣味を楽しむ「活力のあるシニア」像が想像できるイラストを主題にし、参加するだけでも自分がフレイルとは程遠い元気な人だと前向きに思えるようなグラフィックを目指しました。==また、チラシは応募フォームとして使用することを前提としているため、字が書きやすい厚手の上質紙への印刷で発注を行っています。そのようなこだわりも伝わってか、作成したデザインも変更なく2年連続でご利用いただいております。
        '
    />
  </div>

  <div class="sections-list">
  <SectionHeader subtitle="沖縄セルラー様 | ちゅらウォーク(2022~2024年)" title="CASE-02"/>

    <!-- イベント講座 -->
    <ContentSection
        title='「ちゅらウォーク」とは'
        maintext='沖縄セルラー様が提供するヘルスケアアプリ「JOTOホームドクター」を用いて沖縄県とタッグを組んで開催するスマホで簡単に参加できるウォーキングイベントです。イベント中に本イベントに参加すると、歩くだけでポイントが貯まり、抽選でお得な豪華景品が当たるというイベントです。
        あまり歩かないことで有名なうちなんちゅに向けたちょっとでも歩きたくなるイベントとなっています。
        '
    />
    <FeatureCarousel images={[
      { src: "/img/event-graphics/event-graphics-002.jpg", alt: "沖縄セルラー様 | ちゅらウォークチラシ", caption: "沖縄を代表する動物や植物がわいわいと賑わって集まっていて、沖縄全体が賑わっているイメージを目指しました" },
    ]} />
    <ContentSection
        title='みんなイキイキ！ロゴもイキイキ！'
        maintext='「みんなイキイキWELLNESS ISLAND」というテーマに沿って、==県全体がウォーキングを通して活力に溢れた夏になるイメージで、沖縄を代表する動物や植物がわいわいと賑わって集まっているロゴを目指しました。==
        初期案を提出したところ、健康おきなわ21のロゴにもなっている「けんぞう君」をどうにか出したいというお話をいただき、ロゴの中に「けんぞう君」も登場することになりました。
        '
    />
  </div>

  <div class="sections-list">
  <SectionHeader subtitle="三井不動産様 | ゆらり遊舟ぶらり日本橋(2022年)" title="CASE-03"/>

    <!-- イベント講座 -->
    <ContentSection
        title='「ゆらり遊舟ぶらり日本橋」とは'
        maintext='「日本をにぎわす、日本橋」をコンセプトにされている「コレド室町」と日本橋で江戸時代から盛んだった「舟遊び」に関連したスポットを巡るスタンプラリーイベントとなっています。
        三越駅前、日本橋、小舟町、兜町・茅場町の4エリアを跨いで、まだまだ知られていないおすすめスポットや隠れた名店をスタンプラリーを通して紹介する実証実験型のツアーです。このイベント限定の舟運ツアーも同時に販売されました。
        '
    />
    <FeatureCarousel images={[
      { src: "/img/event-graphics/event-graphics-003.jpg", alt: "三井不動産様 | ゆらり遊舟ぶらり日本橋LP", caption: "コレド室町にゆかりのある藍染を背景グラフィックに、LPを制作。" },
    ]} />
    <!-- イベント講座 -->
    <ContentSection
        title='和モダンな世界観を目指して'
        maintext='本案件では、イラストレーター・鈴木二郎さんへのイラスト制作依頼、外注によるロゴデザインがすでに決定されていたため、プロジェクト開始時点で全体の世界観がしっかりと確立されていました。
        自分はLP制作から参画したため、その世界観をさらに広げ、深みを持たせることを目標にデザインの検討を進めました。==コレド室町にゆかりのある藍染をメインモチーフに据え、和の趣とモダンな洗練さを融合させたページを目指しました。==
        登録されている店舗を紹介するため、簡易的な==地図を全4エリア分作成し、スポットの大体の位置がLPでわかる工夫をしています。==
        '
    />
  </div>

  <!-- 関連リンク -->
  <RelatedLinks links={[
    { href: "https://www.city.kakamigahara.lg.jp/kenkofukushi/koureisha/1002527/1021399/1015508.html", label: "岐阜県各務原市様 | 『かかみがはらフレイル予防ウォーキング』概要ページ" },
    { href: "https://www.pref.okinawa.lg.jp/iryokenko/kenko/1006219/1031294.html", label: "沖縄セルラー様 | 『ちゅらウォーク』概要ページ" },
    { href: "https://static.cld.navitime.jp/walkingapp-storage/common/stamprally/nihonbashi_2022/index.html", label: "三井不動産様 | 『ゆらり遊舟ぶらり日本橋』LP" },
  ]} />

  <!-- Navigation Footer -->
  <NavFooter works={alkooBizWorks} currentId="event-graphics" />

</DetailLayout>
