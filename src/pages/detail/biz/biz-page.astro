---
import DetailLayout from '../../../layouts/DetailLayout.astro';
import ContentHeader from '../../../components/ContentHeader.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ContentSection from '../../../components/ContentSection.astro';
import FeatureCarousel from '../../../components/FeatureCarousel.astro';
import RelatedLinks from '../../../components/RelatedLinks.astro';
import NavFooter from '../../../components/NavFooter.astro';
import { alkooBizWorks } from '../../../data/alkoo_biz';

const work = alkooBizWorks.find(w => w.id === 'biz-page')!;
---

<DetailLayout
  title="法人商材サイト"
  backHref="/alkoo_biz"
  breadcrumb={[
    { label: "TOP", href: "/" },
    { label: "ALKOO法人", href: "/alkoo_biz" },
    { label: "法人商材サイト" },
  ]}
>

  <div class="content-intro">
    <ContentHeader
      variant="detail"
      title="売上の大黒柱である法人商材紹介サイトの製作。\nデザイン作成から運用まで担当。伝えきれていなかった商材、過去の実績をまとめて見える化。"
      description="埼玉県が誇る名物キャラクター「コバトン」を看板に据えた、埼玉県民の健康増進サービスの立ち上げからデザイン作成を担当。\nサービスの設計から、ユーザー情報確認ツールの設計など、初となる自治体サービスの立ち上げを行いました。"
      tags={work.tags}
      period="2022年12月〜2023年2月"
      tasks={["情報設計","レイアウト設計","デザイン作成","コンテンツ更新"]}
      members={["PM…1名","セールス…2名","エンジニア…2名", "デザイナー…1名"]}
      thoughtBubble="リードデザイナーを担当しました"
      images={[{ src: "/img/biz-pages/img_contents_alkoobiz_pages.png", alt: "法人商材サイト" }]}
      imageLayout="single"
    />

    <!-- 概要 -->
    <ContentSection
        title='ページ概要'
        maintext='「ALKOO」を使った法人イベントや各種商材紹介を一覧化し、営業引き合いにつなげるためのページ。「ALKOO」公式アプリで知名度を上げていき、具体的な商材やできることが気になった担当者との接点となるよう設計。'
    />
  </div>

  <div class="sections-list">
    <SectionHeader subtitle="ページ公開までの道のり" title="STORY" />
    
    <!-- 開発経緯 -->
    <ContentSection
        title='増えすぎた商材、取り組んだ案件、まとまったページがない…'
        maintext='ALKOO法人パッケージが始まった当初は健康経営支援に向けたパッケージ販売が主流でした。
        アプリの機能が増えるにつれ、法人のお客様からの要望をいただくこともあり、次第にパッケージとして提供できるものが増え続け、==2023年には6つのパッケージに拡大、ですが、その全貌をユーザーにはお伝えしきれていない状況でした。==
        '
    />

    <ContentSection
        title='LP製作を主導'
        maintext='ALKOOで取り扱っている6つの商材（健康経営支援パッケージ、イベントパッケージ、コース掲載、スタンプラリー、ALKOO CONNECT(API連携)、OEM製作）をはじめ、過去の事例のうち公開が可能なものがあるかを整理。
        各商材で伝えたいこと、他との優位性のある箇所など、==miro上でコンテンツを洗い出し、セールス・PM・エンジニアとの定期MTGで整理を行い、LPのワイヤーフレーム設計・叩き台の製作を進めました。==
        '
    />

    <!-- Feature Image -->
    <FeatureCarousel images={[
      { src: "/img/biz-pages/img_contents_alkoobiz_pages_cap001.jpg", alt: "製作の流れ", caption: "上流工程から参加し、LP製作を主導" },
    ]} />

    <ContentSection
        title='実装後の実績更新やデザイン改善の運用を担当'
        maintext='エンジニアの手を離れた後、法人の引き合い数向上施策として公式サイトの改善運用を担当。Astroフレームワークでできたサイトを1人で改善、実績の更新なども進めてきました。
        ==SEOの向上に向けてコンテンツの更新をしたり、サイトのCVR向上に向けてHTMLの構造やレイアウトの整理をするなど根気強く細やかな改善を進めています。==
        '
    />

  </div>

  <!-- 反響 -->
  <div class="sections-list">
    <SectionHeader subtitle="反響" title="OUTCOME"/>

    <ContentSection
      title='自治体やアップデートに関連した引き合いの増加。'
      maintext='サイトが整備されていなかった、2022年ごろはコロナ禍の影響もあったため健康経営施策の引き合いしかありませんでした。
      サイトをリニューアルし、事例・商材を定期的に更新し、詳細な内容を伝えるようになってから==自治体の方の引き合いや日陰ルートなどの関連アップデートを見た方からの引き合いが増加。==正しく自分たちの活動を伝えられるようになりました。'
    />

    <FeatureCarousel images={[
      { src: "/img//biz-pages/img_contents_alkoobiz_pages_cap002.jpg", alt: "法人商材サイトの一部デザイン", caption: "法人商材サイトの一部デザイン" },
    ]} />
  </div>

  <!-- 関連リンク -->
  <RelatedLinks links={[
    { href: "https://www.navitime.co.jp/healthcare/", label: "ナビタイムの健康経営・地域周遊支援パッケージ | ALKOO for Business " },
  ]} />

  <!-- Navigation Footer -->
  <NavFooter works={alkooBizWorks} currentId="biz-page" />

</DetailLayout>