---
import DetailLayout from '../../../layouts/DetailLayout.astro';
import ContentHeader from '../../../components/ContentHeader.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ContentSection from '../../../components/ContentSection.astro';
import FeatureCarousel from '../../../components/FeatureCarousel.astro';
import RelatedLinks from '../../../components/RelatedLinks.astro';
import YoutubeEmbed from '../../../components/YoutubeEmbed.astro';
import { alkooBizWorks } from '../../../data/alkoo_biz';

const work = alkooBizWorks.find(w => w.id === 'kobaton')!;
---

<DetailLayout
  title="コバトンALKOOマイレージ"
  backHref="/alkoo_biz"
  breadcrumb={[
    { label: "TOP", href: "/" },
    { label: "ALKOO法人", href: "/alkoo_biz" },
    { label: "コバトンALKOOマイレージ" },
  ]}
>

  <ContentHeader
    variant="detail"
    title="サービス初となる自治体公式サービス。\nALKOOのアップデートでサービスもアップデートされるWin-Winな開発・運用で市民の健康増進活動をサポート。"
    description="埼玉県が誇る名物キャラクター「コバトン」を看板に据えた、埼玉県民の健康増進サービスの立ち上げからデザイン作成を担当。\nサービスの設計から、ユーザー情報確認ツールの設計など、初となる自治体サービスの立ち上げを行いました。"
    tags={work.tags}
    period="2023年7月〜2024年1月"
    tasks={["企画書作成協力","顧客折衝","UI/UX設計","告知物デザイン作成","販促物作成"]}
    members={["PM…1名","セールス…2名","エンジニア…5名", "デザイナー…1名"]}
    images={[{ src: "/img/kobaton/kv.png", alt: "コバトンALKOOマイレージキービジュアル" }]}
    imageLayout="single"
  />

  <!-- 概要 -->
   <ContentSection
        title='サービス概要'
        maintext='埼玉県の健康増進事業。\nALKOOで提供している記録機能をはじめ散歩ルート検索やコース紹介、スタンプラリーなどのウォーキングに特化した機能が評価され採択。'
    />

  <div class="sections-list">
    <SectionHeader subtitle="サービス提供までの道のり" title="STORY" />
    
    <!-- 開発経緯 -->
    <ContentSection
        title='事業初となる公募入札での採択'
        maintext='法人向けのセールスサイトに埼玉県からの引き合いがあり、内容を確認したところ公募案件がこれから開始するため、調査しているというお話をいただきこの案件は開始しました。
        セールスチームとの綿密に打ち合わせを行い、リリース前からサービスイメージの作成、機能面や自社サービスの強みが伝わるような資料作成で案件獲得に助力しました。
        '
    />

    <ContentSection
        title='公募実施時の課題'
        maintext='公募を実施した段階で、すでに同様のアプリの提供を行っていたのですが、アップデートのスピード感とコスト面の二つの課題が顕著になっていました。
        そこで、今回の公募ではアプリ内に埼玉県専用モードを作成し、そちらにログインしていただくことで、ALKOOで提供している有料機能をはじめコバトンALKOOマイレージ専用のサービスも受けれるという構成になりました。
        '
    />

    <!-- UI/UX検討 -->
     <ContentSection
        title='サービスに必要なものを全て作る'
        maintext='採択当初、先方と打ち合わせをしていた専用モードの仕様はかなりシンプルで、歩数に応じたマイレージ配布、マイレージを使った抽選、歩数ランキング程度のもので、かなりシンプルな構成になる予定でした。
        ですが、実態としては、ユーザー情報管理ツールの開発も必要となったため、BFF設計から参画し管理ツールの作成も行うことになりました。'
    />
    
    <!-- Feature Image -->
    <FeatureCarousel images={[
      { src: "/img/shade-route/img_shade_route_cap001@2x.png", alt: "UI・仕様上の工夫" },
    ]} />
  </div>

  <div class="sections-list">
  <SectionHeader subtitle="普及に向けた活動" title="PROMOTION"/>

    <!-- イベント講座 -->
    <ContentSection
        title='イベント参加講座でユーザーのリテラシーを理解'
        maintext='アンケートやユーザー情報を見たところ、利用者の半数が60代以上の高齢者層でした。
        採択当初から決まっていたイベント参加講座を県内53ヶ所で実施。そのうちのいくつかのイベントに自分も参加し、利用者のリテラシーを深く理解する機会になりました。
        '
    />
    <ContentSection
        title='幅広い市民のために、できることはなるべくやる。'
        maintext='ALKOO内でログインを行い本イベントに参加いただくため、通常のサービスよりもかなり複雑な参加方法をとっていました。
        利用者の年齢層も理解していたため、参加方法をまとめた動画の作成を行うことになりました。
        参加方法の案内動画は、アプリのダウンロードから始まっています。そのため、リテラシーが低い方でも順番に従っていけばイベントに参加できるような映像を目指して制作を行いました。'
    />
    <!-- 使い方動画 -->
    <YoutubeEmbed videoId="-D2yIK-orzY" title="コバトンALKOOマイレージ" />
    <ContentSection
        title='チラシや、のぼり。集客ツール作成にも尽力'
        maintext='ALKOO内でログインを行い本イベントに参加いただくため、通常のサービスよりもかなり複雑な参加方法をとっていました。
        利用者の年齢層も理解していたため、参加方法をまとめた動画の作成を行うことになりました。
        参加方法の案内動画は、アプリのダウンロードから始まっています。そのため、リテラシーが低い方でも順番に従っていけばイベントに参加できるような映像を目指して制作を行いました。'
    />
    <FeatureCarousel images={[
      { src: "/img/kobaton/img_kobaton_cap002.jpg", alt: "UI・仕様上の工夫", caption: "のぼりやマグネットステッカーを作成し、サービスの周知に活用しました" },
    ]} />
  </div>

  <!-- 反響 -->
  <div class="sections-list">
    <SectionHeader subtitle="反響" title="OUTCOME"/>

    <ContentSection
      title='テレビ掲載によるプレミアム課金5倍'
      maintext='2022年の「日陰マップ」の時点で10件以上のテレビ放映をしていましたが、「日陰ルート」になって以降も毎年夏になるとテレビ放映が行われ、毎年5件以上のテレビ掲載がされました。
      また、Xでは美容系のインフルエンサーアカウントに機能を紹介してもらい17万imp、約260件リポストされ、猛暑下でも歩く必要があることの大きな需要を改めて認識することができました。'
    />
  </div>

  <!-- 関連リンク -->
  <RelatedLinks links={[
    { href: "https://www.g-mark.org/gallery/winners/18089", label: "「日陰ルート」グッドデザイン受賞ページ" },
    { href: "https://corporate.navitime.co.jp/topics/pr/202307/20_5618.html", label: "株式会社ナビタイムジャパン「ALKOO by NAVITIME」にて、「日陰ルート」を公開開始" },
    { href: "https://static.cld.navitime.jp/walkingapp-storage/common/lp/shaderoute/index.html", label: "暑さ対策機能ご紹介(日陰マップ/日陰ルート) | ALKOO by NAVITIME" },
  ]} />

  <!-- Navigation Footer -->
  <nav class="nav-footer">
    <a href="/alkoo" class="nav-button">
      <span class="material-icons">arrow_back</span>
      <span>日陰ルート機能</span>
    </a>
    <a href="#" class="nav-button">
      <span>散歩ルート機能</span>
      <span class="material-icons">arrow_forward</span>
    </a>
  </nav>

</DetailLayout>
