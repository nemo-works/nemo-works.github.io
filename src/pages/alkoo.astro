---
import ServicePageLayout from '../layouts/ServicePageLayout.astro';
import WorkItem from '../components/WorkItem.astro';
import { alkooWorks } from '../data/alkoo';
---

<ServicePageLayout
    pageTitle="ALKOO by NAVITIME - Soma Nemoto Portfolio"
    subtitle="自社サービス運用/ウォーキングアプリ"
    title="ALKOO by NAVITIME"
    description="ウォーキングを楽しむ人の一歩踏み出す気持ちを支え、運動の習慣づくりを支援する、歩数計機能を中心としたウォーキングアプリです。\n入社初年度より先任のデザイナーから引き継ぎ、機能検討を始めとするグロース施策からUIUXデザインまで、アプリサービスのデザイン・運営・マネタイズの全般を幅広く経験してきたコアとなるサービスです。"
    period="2019年7月〜2026年現在"
    tasks={["アプリ運営", "グロース施策" , "機能検討" , "グラフィック作成", "展示ブース"]}
    thoughtBubble='7年にわたりメインデザイナーを担当しています'
    members={["PM…1名", "エンジニア…2~8名", "デザイナー…1~3名"]}
    images={[{ src: "/img/alkoo-top/kv.png", alt: "ALKOO Features" }]}
    imageLayout="single"
    breadcrumb={[
        { label: "HOME", href: "/" },
        { label: "ALKOO by NAVITIME" }
    ]}
>
    {alkooWorks.map(work => (
        <WorkItem
            href={work.href}
            thumbnail={work.thumbnail}
            listTitle={work.listTitle}
            listDescription={work.listDescription}
            tags={work.tags}
        />
    ))}
</ServicePageLayout>
