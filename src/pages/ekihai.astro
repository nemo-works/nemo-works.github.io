---
import DetailLayout from '../layouts/DetailLayout.astro';
import ContentHeader from '../components/ContentHeader.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ContentSection from '../components/ContentSection.astro';
import FeatureCarousel from '../components/FeatureCarousel.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

const work = {
  tags: ["UIUX", "機能検討", "顧客折衝", "告知物デザイン作成"],
};
---

<DetailLayout
  title="駅からハイキング アプリリニューアル"
  backHref="/"
  breadcrumb={[
    { label: "TOP", href: "/" },
    { label: "駅からハイキング"}
  ]}
>

  <div class="content-intro">
    <ContentHeader
      variant="detail"
      title="鉄道会社提供のハイキングサービス最大手「駅からハイキング」リニューアル版アプリの製作を受託。\nユーザーとコースをつなぐ、楽しいハイキングの接点を目指して。"
      description="サービス開始から25周年を誇るハイキングサービス「駅からハイキング」のリニューアル版アプリを作成。\nウォーキング分野で最大手を担っていた中枢のサービス。"
      tags={work.tags}
      period="2023年7月〜2024年4月"
      tasks={["顧客折衝","UI/UX設計","告知物デザイン作成"]}
      members={["PM…1名","セールス…3名","エンジニア…6名", "デザイナー…3名"]}
      thoughtBubble='リードデザイナーを担当しました'
      images={[{ src: "/img/ekihai/kv.jpg", alt: "駅からハイキングアプリ" }]}
      imageLayout="single"
    />

    <!-- 概要 -->
    <ContentSection
        title='サービス概要'
        maintext='JR東日本様が提供する、駅を起点に街の新しい魅力を見つけることができるハイキングサービス「駅からハイキング」。
        法人商材サイトと実際にALKOOで提供していた機能を使っていただいた上で、リニューアルアプリの制作に採択されました。コースの紹介や予約、参加したコースの振り返りをすることができるサービスをアプリで提供しています。'
    />
  </div>

  <div class="sections-list">
    <SectionHeader subtitle="サービス提供までの道のり" title="STORY" />
    
    <!-- 開発経緯 -->
    <ContentSection
        title='リニューアルに至った経緯'
        maintext='ご依頼をいただいた当初、すでにアプリの提供はされていましたが、WebViewが主コンテンツとなっており、コースの実利用数の計測や実際に歩いたかを判定することが難しい状況でした。
        その上、コースを実施するにあたって、コースを地図上に書いたチラシを協力会社に依頼して印刷してもらう必要があり、==コスト面での課題からコース開催ができない事例もあり、アプリ配信で解決したいということが開発依頼の発端でした。==
        '
    />

    <ContentSection
        title='アプリのUIとコースデータベースを並行し、要件を洗い出していく。'
        maintext='既存のデータベースはありましたが、コース形状の配信やスポットごとにクーポン情報を追加するためデータベースを一新。
        アプリのUIUX検討と並行することで必要な要素を洗い出しを行っていきました。
        '
    />
    
    <!-- Feature Image -->
    <FeatureCarousel images={[
      { src: "/img/shade-route/img_shade_route_cap001@2x.png", alt: "UI・仕様上の工夫" },
    ]} />
  </div>

  <!-- 反響 -->
  <div class="sections-list">
    <SectionHeader subtitle="反響" title="OUTCOME"/>

    <ContentSection
      title='JR東日本様のJRE ID経済圏拡大に向けて'
      maintext='2022年の「日陰マップ」の時点で10件以上のテレビ放映をしていましたが、「日陰ルート」になって以降も毎年夏になるとテレビ放映が行われ、毎年5件以上のテレビ掲載がされました。
      また、Xでは美容系のインフルエンサーアカウントに機能を紹介してもらい17万imp、約260件リポストされ、猛暑下でも歩く必要があることの大きな需要を改めて認識することができました。'
    />
  </div>

  <!-- 関連リンク -->
  <RelatedLinks links={[
    { href: "https://jrekihai.com/web", label: "駅からハイキング | ポータルサイト" },
    { href: "https://jrekihai.com/web/app-introduction", label: "駅からハイキング | アプリ紹介サイト" },
    { href: "https://share.google/TSwYKFhShETjYUJK3", label: "JR東日本様 | プレスリリース" },
  ]} />

  <!-- Navigation Footer -->
  <nav class="nav-footer">
    <a href="/alkoo" class="nav-button">
      <span class="material-icons">arrow_back</span>
      <span>日陰ルート機能</span>
    </a>
    <a href="#" class="nav-button">
      <span>散歩ルート機能</span>
      <span class="material-icons">arrow_forward</span>
    </a>
  </nav>

</DetailLayout>