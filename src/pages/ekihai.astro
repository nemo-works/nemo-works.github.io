---
import DetailLayout from '../layouts/DetailLayout.astro';
import ContentHeader from '../components/ContentHeader.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ContentSection from '../components/ContentSection.astro';
import FeatureCarousel from '../components/FeatureCarousel.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import NavFooter from '../components/NavFooter.astro';

const work = {
  tags: ["UIUX", "機能検討", "顧客折衝", "告知物デザイン作成"],
};
---

<DetailLayout
  title="駅からハイキング アプリリニューアル"
  backHref="/"
  breadcrumb={[
    { label: "TOP", href: "/" },
    { label: "駅からハイキング"}
  ]}
>

  <div class="content-intro">
    <ContentHeader
      variant="detail"
      client="東日本旅客鉄道株式会社様"
      title="鉄道会社提供のハイキングサービス最大手「駅からハイキング」\nリニューアル版アプリの製作を受託。ユーザーとコースをつなぐ、楽しいハイキングの接点を目指して。"
      description="サービス開始から25周年を誇るハイキングサービス「駅からハイキング」のリニューアル版アプリを作成。\nウォーキング分野で最大手を担っていた中枢サービスのアプリリニューアルをウォーキングアプリの運用実績から採用。"
      tags={work.tags}
      period="2023年7月〜2024年4月"
      tasks={["顧客折衝","UI/UX設計","告知物デザイン作成"]}
      members={["PM…1名","セールス…3名","エンジニア…6名", "デザイナー…3名"]}
      thoughtBubble='リードデザイナーを担当しました'
      images={[{ src: "/img/ekihai/kv.jpg", alt: "駅からハイキングアプリ" }]}
      imageLayout="single"
    />

    <!-- 概要 -->
    <ContentSection
        title='サービス概要'
        maintext='JR東日本様が提供する、駅を起点に街の新しい魅力を見つけることができるハイキングサービス「駅からハイキング」。
        法人商材サイトと実際にALKOOで提供していた機能を使っていただいた上で、リニューアルアプリの制作に採択されました。コースの紹介や予約、参加したコースの振り返りをすることができるサービスをアプリで提供しています。'
    />
  </div>

  <div class="sections-list">
    <SectionHeader subtitle="サービス提供までの道のり" title="STORY" />
    
    <!-- 開発経緯 -->
    <ContentSection
        title='リニューアルに至った経緯'
        maintext='ご依頼をいただいた当初、すでにアプリの提供はされていましたが、WebViewが主コンテンツとなっており、コースの実利用数の計測や実際に歩いたかを判定することが難しい状況でした。
        その上、コースを実施するにあたって、コースを地図上に書いたチラシを協力会社に依頼して印刷してもらう必要があり、==コスト面での課題からコース開催ができない事例もあり、アプリ配信で解決したいということがご依頼の発端でした。==
        '
    />

    <ContentSection
        title='現地視察を通して必要な情報と運用実態を調査'
        maintext='「駅ハイ」というイベントはすでに知っていましたが、==どのように運用しているかを理解するため、現地視察を実施しました。==
        「駅からハイキング」は基本的に駅起点となるため、駅員さんがイベント開始時に==駅で受付を行い地図を手渡しし、ユーザーが歩き出すという流れになっています。==
        '
    />
    
    <!-- Feature Image -->
    <FeatureCarousel images={[
      { src: "/img/ekihai/img_ekihai_cap001.jpg", alt: "池袋駅構内で実施していた案内", caption: "池袋駅構内で実施していた案内。Webサイトやアプリでの周知に加えて駅内での案内も豊富。"},
      { src: "/img/ekihai/img_ekihai_cap002.jpg", alt: "看板を持った駅員さんがイベントの開始場所までの案内を実施している。", caption: "看板を持った駅員さんがイベントの開始場所までの案内を実施している。"},
    ]} />
  </div>

  <div class="sections-list">
    <SectionHeader subtitle="UI・コース入稿ツールの設計" title="DESIGN" />
    <ContentSection
        title='理解した駅ハイの魅力'
        maintext='駅ハイに参加することで、ファンが多くいる理由が理解できました。その土地を知り尽くした駅員さんたちが作り上げるコースは普段なら見つけることもできないような魅力に溢れていて、街の新しい魅力に気づくことを実感しました。
        紙地図は非常に詳細にできていて目印となる建物の記載があったり、道の注意点を教えてくれるため非常にわかりやすかったです。一方で、==紙地図はサイズが大きく、しまったり出したりが大変で手元が少し慌ただしくなる==問題も理解しました。
        '
    />

    <ContentSection
        title='行ったからこそわかる出したい情報の整理'
        maintext='10月ごろの現地参加のタイミングですでにワイヤーフレームの着手はしていましたが、現地参加を通して==「駅と別の受付場所(スタート場所)の記載の必要性」や「コースの注意事項を充実の必要性」など新しい発見==が多数ありました。
        実際に行って気付いた情報をもとにワイヤーフレームのアップデートを行い、==2週に1回程度、アプリUIについても直接担当者様と話し合い改善==それ以外にもSlack上でUIの相談をしながらアプリのデザインを進めていきました。
        '
    />

    <ContentSection
        title='アプリデザインと並行しコース入稿ツール作成。UIデザイナーとしての真髄を自覚。'
        maintext='アプリデザインのワイヤーフレーム作成と並行して、コース入稿ツールについても制作を進めていました。
        地図上の経路入力から、立ち寄りスポットの入力など、ユーザーが目にする情報の全てが入力できるツールになっていたため、そのデータの構造や各項目のデータタイプや入力規制などを把握する必要がありました。
        同時にアプリのデザインも作成していたため、アプリ上に出したい情報と入稿ツールの情報の統一を図れるのは自分だけだと、UIデザイナーとしての真の立ち位置を改めて自覚し、DB設計のMTGから同席。
        ==ユーザーのアプリの見え方から、担当者が入力する情報まで。プロダクトの全ての情報を一貫して繋げていくため、データとサービスのハブになるように意識して行動をしていました。==
        '
    />

    <FeatureCarousel images={[
      { src: "/img/ekihai/img_ekihai_cap003.jpg", alt: "アプリUI（左：ホーム画面 | 中央：記録タブ | 右：コース地図）", caption: "アプリUI（左：ホーム画面 | 中央：記録タブ | 右：コース地図）"},
      { src: "/img/ekihai/img_ekihai_cap004.jpg", alt: "特にこだわって追加した仕様", caption: "ホーム画面・コース詳細画面で特にこだわって追加した仕様"},
      { src: "/img/ekihai/img_ekihai_cap005.jpg", alt: "多様な参加者を表現できるよう、歩く人はコンポーネントの組み合わせで10パターン以上作成ができる。", caption: "多様な参加者を表現できるよう、歩く人はコンポーネントの組み合わせで10パターン以上作成ができる。"},
    ]} />
  </div>

  <!-- 反響 -->
  <div class="sections-list">
    <SectionHeader subtitle="反響" title="OUTCOME"/>

    <ContentSection
      title='地図を印刷しなくても、コース開催が可能に。'
      maintext='コース地図の印刷・配布は任意となり、参加者はコースの確認から歩行、コースの記録までもアプリ1つで完結できるようになりました。
      アプリのリニューアルによって==地図を制作するコストがかけれない駅でもイベントの開催が可能になりました。==
      また、駅からタクシー旅行をするプランやランニングのコースも案内できるようになり、駅発の旅を提供する一つのプラットホーム的な役割を駅ハイアプリで担うようになりました。
      '
    />
    <ContentSection
      title='コースの情報が今まで以上に身近になった。'
      maintext='ホーム画面ですぐにコース情報へアクセスできるようになったことで、コースの開催情報、おすすめコースを提案できるようになりました。また、こだわって追加したお気に入りの機能で事前に行きたいコースを保存して置けるようになり、==お客様が作ったコースが今まで以上にユーザーにとって身近な存在になりました。==
      担当者様からも「ワクワク感がいっぱいです！」とおっしゃっていただき、こだわってつくったUIにご好評いただきました。
      '
    />
  </div>

  <!-- 関連リンク -->
  <RelatedLinks links={[
    { href: "https://jrekihai.com/web", label: "駅からハイキング | ポータルサイト" },
    { href: "https://jrekihai.com/web/app-introduction", label: "駅からハイキング | アプリ紹介サイト" },
    { href: "https://share.google/TSwYKFhShETjYUJK3", label: "JR東日本様 | プレスリリース" },
  ]} />

  <!-- Navigation Footer -->
  <NavFooter
    prev={{ label: "日陰ルート機能", href: "/alkoo" }}
    next={{ label: "散歩ルート機能", href: "#" }}
  />

</DetailLayout>