---
import ServicePageLayout from '../layouts/ServicePageLayout.astro';
import WorkItem from '../components/WorkItem.astro';
import { dValuePassWorks } from '../data/d_value_pass';
---

<ServicePageLayout
    pageTitle="ALKOO by NAVITIME - Soma Nemoto Portfolio"
    subtitle="自社サービス運用/ナビゲーションサービス"
    title="dバリューパス向けコンテンツ"
    description="株式会社NTTドコモ様が提供している「dバリューパス」ユーザー専用のナビゲーションサービス各種のデザインを担当\n"
    period="2022年4月〜2026年現在"
    tasks={["アプリ運営", "グロース施策" , "機能検討" , "グラフィック作成"]}
    members={["PM…1名", "エンジニア…4~8名", "デザイナー…1~3名"]}
    images={[{ src: "/img/alkoo-top/kv.png", alt: "ALKOO Features" }]}
    imageLayout="single"
    breadcrumb={[
        { label: "HOME", href: "/" },
        { label: "dバリューパス向けコンテンツ" }
    ]}
>
    {dValuePassWorks.map(work => (
        <WorkItem
            href={work.href}
            thumbnail={work.thumbnail}
            listTitle={work.listTitle}
            listDescription={work.listDescription}
            tags={work.tags}
        />
    ))}
</ServicePageLayout>
