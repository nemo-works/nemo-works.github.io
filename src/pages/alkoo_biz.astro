---
import ServicePageLayout from '../layouts/ServicePageLayout.astro';
import WorkItem from '../components/WorkItem.astro';
import { alkooBizWorks } from '../data/alkoo_biz';
---

<ServicePageLayout
    pageTitle="ALKOO by NAVITIME - Soma Nemoto Portfolio"
    subtitle="クライアントワーク/サービス立ち上げ"
    title="ALKOO 法人案件"
    description="ALKOOを用いた健康経営施策や、自治体の健康増進施策、「歩く」を起点にしたイベントへの技術協力をはじめとするクライアントワーク。また、法人案件の引き合い獲得に向けたグロース施策なども行なっています。"
    period="2021年4月〜2026年3月"
    tasks={["UI/UX検討", "グラフィック作成", "展示ブース"]}
    members={["PM…1名","エンジニア…4名", "デザイナー…1名"]}
    images={[{ src: "/img/alkoo-biz/kv.jpg", alt: "ALKOO Features" }]}
    imageLayout="single"
    breadcrumb={[
        { label: "HOME", href: "/" },
        { label: "ALKOO 法人案件" }
    ]}
>
    {alkooBizWorks.map(work => (
        <WorkItem
            href={work.href}
            thumbnail={work.thumbnail}
            listTitle={work.listTitle}
            listDescription={work.listDescription}
            tags={work.tags}
        />
    ))}
</ServicePageLayout>
