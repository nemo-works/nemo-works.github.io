---
import MenuDialog from '../components/MenuDialog.astro';

interface Props {
    title: string;
    bodyBg?: string;
}

const { title, bodyBg = 'var(--gray-white)' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex">
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Inter:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body style={`background: ${bodyBg};`}>
    <slot />
    <MenuDialog
      topLinks={[
        { label: "TOP", href: "/" },
      ]}
      sections={[
        {
          title: "WORKS",
          items: [
            { label: "ALKOO", href: "/alkoo" },
            { label: "駅からハイキング", href: "/ekihai" },
            { label: "コバトンALKOOマイレージ", href: "/kobaton" },
            { label: "ALKOO 法人サービス", href: "/alkoo_biz" },
            { label: "dバリューパス", href: "/d-value-pass" },
            { label: "社内デザインの底上げ", href: "#" },
          ],
        },
      ]}
      bottomLinks={[
        { label: "PROFILE", href: "/#profile" },
      ]}
    />
</body>
</html>

<style is:global>
    @import '../styles/global.css';
</style>
