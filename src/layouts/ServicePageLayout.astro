---
import BaseLayout from './BaseLayout.astro';
import ContentHeader from '../components/ContentHeader.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SiteHeader from '../components/SiteHeader.astro';

interface ImageItem {
  src: string;
  alt: string;
}

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  pageTitle: string;
  subtitle?: string;
  title: string;
  description: string;
  tags?: string[];
  period: string;
  tasks: string[];
  members: string[];
  thoughtBubble?: string;
  images?: ImageItem[];
  imageLayout?: 'single' | 'multi';
  breadcrumb?: BreadcrumbItem[];
}

const { pageTitle, subtitle, title, description, tags, period, tasks, members, thoughtBubble, images, imageLayout, breadcrumb } = Astro.props;
---

<BaseLayout title={pageTitle} bodyBg="var(--gray-background)">
    <!-- Header -->
    <SiteHeader variant="back" backHref="/" />

    <!-- Breadcrumb -->
    {breadcrumb && (
        <nav class="breadcrumb" aria-label="パンくずリスト">
            <ol class="breadcrumb-list">
                {breadcrumb.map((item, index) => (
                    <li class="breadcrumb-item">
                        {item.href
                            ? <a href={item.href} class="breadcrumb-link">{item.label}</a>
                            : <span class="breadcrumb-current" aria-current="page">{item.label}</span>
                        }
                        {index < breadcrumb.length - 1 && (
                            <span class="breadcrumb-separator" aria-hidden="true">›</span>
                        )}
                    </li>
                ))}
            </ol>
        </nav>
    )}

    <!-- Main Content -->
    <main class="main-content">
        <!-- Hero Section -->
        <section class="hero-section">
            <ContentHeader
                subtitle={subtitle}
                title={title}
                description={description}
                tags={tags}
                period={period}
                tasks={tasks}
                members={members}
                thoughtBubble={thoughtBubble}
                images={images}
                imageLayout={imageLayout}
            />
        </section>

        <!-- Works List -->
        <section class="works-list">
            <SectionHeader subtitle="制作物" title="WORKS" />
            <slot />
        </section>
    </main>
</BaseLayout>

<style>
    /* Main Content */
    .main-content {
        max-width: var(--max-width);
        margin: 0px auto 0 auto;
        border-left: 1px solid var(--gray-divider);
        border-right: 1px solid var(--gray-divider);
    }

    /* Breadcrumb */
    .breadcrumb {
        max-width: var(--max-width);
        margin: 80px auto 20px auto;
    }

    .breadcrumb-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 4px;
    }

    .breadcrumb-item {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: var(--fs-body);
        color: var(--gray-sub);
    }

    .breadcrumb-link {
        color: var(--gray-sub);
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb-link:hover {
        color: var(--gray-main);
        text-decoration: underline;
    }

    .breadcrumb-current {
        color: var(--gray-main);
    }

    .breadcrumb-separator {
        color: var(--gray-sub);
        font-size: 1.1em;
    }

    /* Works List */
    .works-list {
        background: var(--gray-white);
        padding: 40px 0;
        display: flex;
        flex-direction: column;
        gap: 40px;
    }

    /* Responsive */
    @media (max-width: 1440px) {
        .main-content {
            padding: 100px 100px 0px 100px;
        }
    }

    @media (max-width: 1024px) {
        .main-content { 
            padding-left: 60px;
            padding-right: 60px;
            border-left: 1px solid var(--gray-divider);
            border-right: 1px solid var(--gray-divider);
        }
    }

    @media (max-width: 768px) {
        .breadcrumb {
            margin: 80px 20px 20px 40px;
        }

        .main-content { 
            padding: 0px;
            margin: 0px 20px 0 20px;
            
        }
    }
</style>
